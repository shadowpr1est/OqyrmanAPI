APP_HOST=0.0.0.0
APP_PORT=8080
APP_ENV=production

SWAGGER_HOST=<ip>:<port>

# ALLOWED_ORIGINS — укажите домен фронтенда, например https://oqyrman.app
# Для локальной разработки можно оставить *
ALLOWED_ORIGINS=https://oqyrman.app

DB_HOST=postgres
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=oqyrman
# В продакшне используйте require или verify-full
DB_SSLMODE=require

JWT_SECRET=
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAY=30

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_URL=https://api.oqyrman.app/minio
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=oqyrman
# В продакшне установите true
MINIO_USE_SSL=true

ANTHROPIC_API_KEY=
