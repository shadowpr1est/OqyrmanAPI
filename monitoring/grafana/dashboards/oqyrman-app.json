      "targets": [ { "expr": "histogram_quantile(0.95, sum by (le) (rate(oqyrman_http_request_duration_seconds_bucket[5m])))", "refId": "A" } ],
      "title": "p95 Latency",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
