      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "expr": "sum(oqyrman_http_in_flight_requests)", "refId": "A" } ],
      "title": "In Flight Requests",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "expr": "100 * sum(rate(oqyrman_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(oqyrman_http_requests_total[5m]))", "refId": "A" } ],
      "title": "5xx Rate %",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": [ "lastNotNull", "max" ] }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(oqyrman_http_request_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(oqyrman_http_request_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(oqyrman_http_request_duration_seconds_bucket[5m]))) * 1000", "legendFormat": "p99", "refId": "C" }
      ],
      "title": "Request Latency",
      "type": "timeseries"
    },
