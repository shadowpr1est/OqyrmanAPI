    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "expr": "sum(rate(pg_stat_database_xact_commit[5m])) + sum(rate(pg_stat_database_xact_rollback[5m]))", "refId": "A" } ],
      "title": "Transactions / sec",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "expr": "pg_stat_database_numbackends", "refId": "A" } ],
      "title": "Active Connections",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": [ "lastNotNull" ], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [ { "expr": "pg_database_size_bytes", "refId": "A" } ],
      "title": "DB Size",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": [ "lastNotNull", "max" ] }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [
        { "expr": "rate(pg_stat_database_tup_returned[5m])", "legendFormat": "returned", "refId": "A" },
        { "expr": "rate(pg_stat_database_tup_fetched[5m])", "legendFormat": "fetched", "refId": "B" },
        { "expr": "rate(pg_stat_database_tup_inserted[5m])", "legendFormat": "inserted", "refId": "C" },
        { "expr": "rate(pg_stat_database_tup_updated[5m])", "legendFormat": "updated", "refId": "D" },
        { "expr": "rate(pg_stat_database_tup_deleted[5m])", "legendFormat": "deleted", "refId": "E" }
      ],
      "title": "Tuple Activity",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
